import sqlite3


class Block:
    def __init__(self, id, view, desc, img):
        self.id = id
        self.view = view
        self.desc = desc
        self.img = img

    @staticmethod
    def get_all(conn):
        cur = conn.cursor()
        cur.execute("SELECT * FROM BLOCKS")
        return cur.fetchall()


class Person:
    def __init__(self, id, name, addr):
        self.id = id
        self.name = name
        self.addr = addr

    @staticmethod
    def get_all(conn):
        cur = conn.cursor()
        cur.execute("SELECT * FROM PERSONS")
        return cur.fetchall()



class Source:
    def __init__(self, id, ip_addr, country_code):
        self.id = id
