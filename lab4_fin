class Vote:
    def __init__(self, block_id, voter_id, timestamp, source_id):
        self.block_id = block_id
        self.voter_id = voter_id
        self.timestamp = timestamp
        self.source_id = source_id

    @staticmethod
    def get_all(conn):
        cur = conn.cursor()
        cur.execute("SELECT * FROM VOTES")
        return cur.fetchall()

    


